#ifndef TINY_BCLIBC_VERSION_H
#define TINY_BCLIBC_VERSION_H

#define TINY_BCLIBC_VERSION_MAJOR @TINY_BCLIBC_VERSION_MAJOR@
#define TINY_BCLIBC_VERSION_MINOR @TINY_BCLIBC_VERSION_MINOR@
#define TINY_BCLIBC_VERSION_PATCH @TINY_BCLIBC_VERSION_PATCH@
#define TINY_BCLIBC_VERSION "@TINY_BCLIBC_VERSION@"

#if defined(TINY_BCLIBC_SINGLE_PRECISION) || defined(TINY_BCLIBC_USE_FLOAT)
#define TINY_BCLIBC_VERSION_FULL TINY_BCLIBC_VERSION "-sp"
#else
#define TINY_BCLIBC_VERSION_FULL TINY_BCLIBC_VERSION "-dp"
#endif

#endif /* TINY_BCLIBC_VERSION_H */
